<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude sensitive data from cloud backup -->
        <exclude domain="sharedpref" path="encrypted_prefs"/>
        <exclude domain="database" path="secure.db"/>
        <exclude domain="file" path="keys/"/>
    </cloud-backup>
    <device-transfer>
        <!-- Exclude sensitive data from device transfer -->
        <exclude domain="sharedpref" path="encrypted_prefs"/>
        <exclude domain="database" path="secure.db"/>
        <exclude domain="file" path="keys/"/>
    </device-transfer>
</data-extraction-rules>